FROM node:20-alpine AS build
# Optimizar para entornos con poca memoria
ENV NODE_OPTIONS="--max-old-space-size=2048"

# Argumentos de construcción (inyectados por GitHub Actions)
ARG VITE_GOOGLE_DRIVE_CLIENT_ID
ARG VITE_GOOGLE_DRIVE_API_KEY
ARG VITE_GOOGLE_DRIVE_CLIENT_SECRET
ARG VITE_DRIVE_TEMPLATES_FOLDER_ID
ARG VITE_DRIVE_DESTINATION_FOLDER_ID
ARG VITE_GOOGLE_SHEETS_LOG_ID
ARG VITE_PREVIEW_API_URL
ARG GEMINI_API_KEY
ARG VITE_DEEPSEEK_API_KEY
ARG VITE_STORAGE_MODE
ARG VITE_NEXTCLOUD_URL
ARG VITE_NEXTCLOUD_CLIENT_ID
ARG VITE_NEXTCLOUD_CLIENT_SECRET
ARG VITE_NEXTCLOUD_TEMPLATES_PATH
ARG VITE_NEXTCLOUD_DESTINATION_PATH

# Pasar argumentos a variables de entorno para que Vite los vea
ENV VITE_GOOGLE_DRIVE_CLIENT_ID=$VITE_GOOGLE_DRIVE_CLIENT_ID
ENV VITE_GOOGLE_DRIVE_API_KEY=$VITE_GOOGLE_DRIVE_API_KEY
ENV VITE_GOOGLE_DRIVE_CLIENT_SECRET=$VITE_GOOGLE_DRIVE_CLIENT_SECRET
ENV VITE_DRIVE_TEMPLATES_FOLDER_ID=$VITE_DRIVE_TEMPLATES_FOLDER_ID
ENV VITE_DRIVE_DESTINATION_FOLDER_ID=$VITE_DRIVE_DESTINATION_FOLDER_ID
ENV VITE_GOOGLE_SHEETS_LOG_ID=$VITE_GOOGLE_SHEETS_LOG_ID
ENV VITE_PREVIEW_API_URL=$VITE_PREVIEW_API_URL
ENV GEMINI_API_KEY=$GEMINI_API_KEY
ENV VITE_DEEPSEEK_API_KEY=$VITE_DEEPSEEK_API_KEY
ENV VITE_STORAGE_MODE=$VITE_STORAGE_MODE
ENV VITE_NEXTCLOUD_URL=$VITE_NEXTCLOUD_URL
ENV VITE_NEXTCLOUD_CLIENT_ID=$VITE_NEXTCLOUD_CLIENT_ID
ENV VITE_NEXTCLOUD_CLIENT_SECRET=$VITE_NEXTCLOUD_CLIENT_SECRET
ENV VITE_NEXTCLOUD_TEMPLATES_PATH=$VITE_NEXTCLOUD_TEMPLATES_PATH
ENV VITE_NEXTCLOUD_DESTINATION_PATH=$VITE_NEXTCLOUD_DESTINATION_PATH

WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# Etapa de Producción (Serve Stage)
FROM nginx:stable-alpine
# Copiar el build de Vite al directorio de Nginx
COPY --from=build /app/dist /usr/share/nginx/html
# Configurar Nginx para SPA (Single Page Application)
RUN echo 'server { \
    listen 80; \
    location / { \
    root /usr/share/nginx/html; \
    index index.html index.htm; \
    try_files $uri $uri/ /index.html; \
    } \
    }' > /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
